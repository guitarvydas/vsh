unhtml {
  text = htmlchar*
  htmlchar =
      "&amp;nbsp; " -- nbsp
    |  "&amp;nbsp;" -- nbsp2
    |  "&amp;amp;" -- ampamp
    | "&lt;br&gt;" -- br
    | "&#92;"  -- backslash
    | "&amp;gt;" -- agt
    | "&amp;lt;" -- alt
    | "&amp;"  -- amp
    | "&lt;"  -- lt
    | "&gt;"  -- gt
    | "&nbsp;"  -- nonBreakingSpace
    | any      -- any
}

