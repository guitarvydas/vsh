drawiohtml {
  ABORT
  paragraph =
      paragraphstuff* "
  text =
      stuff* span text -- withspan
    | stuff* -- withoutspan

  span = "<span" (~">" any)* ">" notSpanEnd* "</span>"
  notSpanEnd = ~"</span>" any
  stuff = ~"<span" any

  para = "<p" (~">" any)* ">" text "<
  paragraphstuff = ~"<p" any
}

